# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code
.claude/
AGENTS.md
CLAUDE.md

# 大型素材檔（音訊、影片）— 保留逐字稿與 srt 入庫
content/_sources/**/*.mp3
content/_sources/**/*.wav
content/_sources/**/*.mov
content/_sources/**/*.mp4
content/_sources/**/*.m4a
